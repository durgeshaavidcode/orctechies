{
  "name": "oratechies",
  "version": "1.0.0",
  "description": "An enterprise-grade, multi-tenant B2B2C job marketplace and applicant tracking ecosystem designed to bridge job seekers and corporate recruiters through structured data processing and high-volume search metrics.",
  "workspaces": [
    "host-app",
    "auth-mfe",
    "admin-mfe",
    "shared-component"
  ],
  "scripts": {
    "build:all": "npm run build --workspaces",
    "install:all": "npm install",
    "dev:host": "vite dev host-app --port 5000",
    "dev:auth": "npm --workspace=auth-mfe run dev -- --host",
    "dev:admin": "vite dev admin-mfe --port 5002",
    "dev": "concurrently \"npm:dev:host\" \"npm:dev:auth\" \"npm:dev:admin\"",
    
    "build:host": "vite build host-app",
    "build:auth": "vite build auth-mfe",
    "build:admin": "vite build admin-mfe",
    "build": "npm run build:host && npm run build:auth && npm run build:admin",
    
    "preview:host": "vite preview host-app --port 5000",
    "preview:auth": "vite preview auth-mfe --port 5001",
    "preview:admin": "vite preview admin-mfe --port 5002",
    "preview": "concurrently \"npm:preview:host\" \"npm:preview:auth\" \"npm:preview:admin\"",
    
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/durgeshaavidcode/orctechies.git"
  },
  "keywords": [
    "job",
    "marketplace",
    "application",
    "tracking",
    "resume",
    "bridge",
    "job"
  ],
  "author": "durgeshaavidcode",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/durgeshaavidcode/orctechies/issues"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-scripts": "^5.0.1",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7"
  }
}